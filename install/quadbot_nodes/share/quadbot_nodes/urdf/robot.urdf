<?xml version="1.0"?>

<robot name="quadbot">

    <material name="blue">
        <color rgba="0.2 0.2 0.9 1"/>
    </material>
    <material name="green">
        <color rgba="0.2 0.9 0.2 1"/>
    </material>
    <material name="brown">
        <color rgba="0.5 0.2 0.2 1"/>
    </material>
    <material name="teal">
        <color rgba="0.1 0.7 0.5 1"/>
    </material>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.7" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 0.5 0.1"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 0.5 0.1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <mass value="2.0"/>
            <inertia ixx="0.0433" ixy="0" ixz="0" iyy="0.0083" iyz="0" izz="0.0483"/>
        </inertial>
    </link>

    <!-- leg1 front left -->

    <!-- hip pivot - fixed to the body corner -->
    <link name="leg1_mainjoint">
        <visual>
            <geometry>
                <sphere radius="0.04"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.04"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="3.2e-5" ixy="0" ixz="0" iyy="3.2e-5" iyz="0" izz="3.2e-5"/>
        </inertial>
    </link>

    <!-- front-left shoulder - body-colored fixed stub that pushes the front leg forward (+Y) -->
    <link name="leg1_shoulder">
        <visual>
            <origin xyz="0 0.04 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.08 0.11 0.08"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0.04 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.08 0.08 0.08"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0.04 0" rpy="0 0 0"/>
            <mass value="0.2"/>
            <inertia ixx="2.13e-4" ixy="0" ixz="0" iyy="2.13e-4" iyz="0" izz="2.13e-4"/>
        </inertial>
    </link>

    <joint name="leg1_shoulderConnection" type="fixed">
        <parent link="base_link"/>
        <child link="leg1_shoulder"/>
        <origin xyz="0.1 0.15 0.69" rpy="0 0 0"/>
    </joint>

    <joint name="leg1_main" type="fixed">
        <parent link="leg1_shoulder"/>
        <child link="leg1_mainjoint"/>
        <origin xyz="0.06 0.04 0" rpy="0 0 0"/>
    </joint>

    <!-- thigh - hangs down from the hip pivot, swings on the hip joint -->
    <link name="leg1_mainlink">
        <visual>
            <origin xyz="0 0 -0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.25" radius="0.03"/>
            </geometry>
            <material name="brown"/>
        </visual>
        <collision>
            <origin xyz="0 0 -0.13" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.2" radius="0.03"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 -0.15" rpy="0 0 0"/>
            <mass value="0.3"/>
            <inertia ixx="1.56e-3" ixy="0" ixz="0" iyy="1.56e-3" iyz="0" izz="1.35e-4"/>
        </inertial>
    </link>

    <joint name="leg1_mainConnection" type="revolute">
        <parent link="leg1_mainjoint"/>
        <child link="leg1_mainlink"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
    </joint>

    <!-- knee pivot - fixed to the bottom of the thigh -->
    <link name="leg1_2joint">
        <visual>
            <geometry>
                <sphere radius="0.04"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.04"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="3.2e-5" ixy="0" ixz="0" iyy="3.2e-5" iyz="0" izz="3.2e-5"/>
        </inertial>
    </link>

    <joint name="leg1_2Connection" type="fixed">
        <parent link="leg1_mainlink"/>
        <child link="leg1_2joint"/>
        <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    </joint>

    <!-- shin - hangs down from the knee pivot, swings on the knee joint -->
    <link name="leg1_2link">
        <visual>
            <origin xyz="0 0 -0.13" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.25" radius="0.03"/>
            </geometry>
            <material name="brown"/>
        </visual>
        <collision>
            <origin xyz="0 0 -0.13" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.25" radius="0.03"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 -0.13" rpy="0 0 0"/>
            <mass value="0.3"/>
            <inertia ixx="1.56e-3" ixy="0" ixz="0" iyy="1.56e-3" iyz="0" izz="1.35e-4"/>
        </inertial>
    </link>

    <joint name="leg1_2Rotation" type="revolute">
        <parent link="leg1_2joint"/>
        <child link="leg1_2link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
    </joint>

    <!-- ankle pivot - fixed to the bottom of the shin -->
    <link name="leg1_3joint">
        <visual>
            <geometry>
                <sphere radius="0.04"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.04"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="3.2e-5" ixy="0" ixz="0" iyy="3.2e-5" iyz="0" izz="3.2e-5"/>
