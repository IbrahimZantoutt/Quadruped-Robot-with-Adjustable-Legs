    </joint>

    <!-- thigh - hangs down from the hip pivot, swings on the hip joint -->
    <link name="leg4_mainlink">
        <visual>
            <origin xyz="0 0 -0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.25" radius="0.03"/>
            </geometry>
            <material name="brown"/>
        </visual>
        <collision>
            <origin xyz="0 0 -0.13" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.2" radius="0.03"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 -0.15" rpy="0 0 0"/>
            <mass value="0.3"/>
            <inertia ixx="1.56e-3" ixy="0" ixz="0" iyy="1.56e-3" iyz="0" izz="1.35e-4"/>
        </inertial>
    </link>

    <joint name="leg4_mainConnection" type="revolute">
        <parent link="leg4_mainjoint"/>
        <child link="leg4_mainlink"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-1.57" upper="0.8" effort="10" velocity="1"/>
    </joint>

    <!-- knee pivot - fixed to the bottom of the thigh -->
    <link name="leg4_2joint">
        <visual>
            <geometry>
                <sphere radius="0.04"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.04"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="3.2e-5" ixy="0" ixz="0" iyy="3.2e-5" iyz="0" izz="3.2e-5"/>
        </inertial>
    </link>

    <joint name="leg4_2Connection" type="fixed">
        <parent link="leg4_mainlink"/>
        <child link="leg4_2joint"/>
        <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    </joint>

    <!-- shin - hangs down from the knee pivot, swings on the knee joint -->
    <link name="leg4_2link">
        <visual>
            <origin xyz="0 0 -0.13" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.25" radius="0.03"/>
            </geometry>
            <material name="brown"/>
        </visual>
        <collision>
            <origin xyz="0 0 -0.13" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.25" radius="0.03"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 -0.13" rpy="0 0 0"/>
            <mass value="0.3"/>
            <inertia ixx="1.56e-3" ixy="0" ixz="0" iyy="1.56e-3" iyz="0" izz="1.35e-4"/>
        </inertial>
    </link>

    <joint name="leg4_2Rotation" type="revolute">
        <parent link="leg4_2joint"/>
        <child link="leg4_2link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
    </joint>

    <!-- ankle pivot - fixed to the bottom of the shin -->
    <link name="leg4_3joint">
        <visual>
            <geometry>
                <sphere radius="0.04"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.04"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="3.2e-5" ixy="0" ixz="0" iyy="3.2e-5" iyz="0" izz="3.2e-5"/>
        </inertial>
    </link>

    <joint name="leg4_3Connection" type="fixed">
        <parent link="leg4_2link"/>
        <child link="leg4_3joint"/>
        <origin xyz="0 0 -0.28" rpy="0 0 0"/>
    </joint>

    <!-- foot - short stub hanging from the ankle pivot -->
    <link name="leg4_3link">
        <visual>
            <origin xyz="0 0 -0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.07" radius="0.02"/>
            </geometry>
            <material name="brown"/>
        </visual>
        <collision>
            <origin xyz="0 0 -0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.07" radius="0.02"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 -0.05" rpy="0 0 0"/>
            <mass value="0.05"/>
            <inertia ixx="2.0e-5" ixy="0" ixz="0" iyy="2.0e-5" iyz="0" izz="1.0e-5"/>
        </inertial>
    </link>

    <joint name="leg4_3Rotation" type="revolute">
        <parent link="leg4_3joint"/>
        <child link="leg4_3link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
    </joint>

    <!-- wheel - spins freely about its axle at the end of the foot -->
    <link name="leg4_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
            <material name="teal"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="7.0e-5" ixy="0" ixz="0" iyy="7.0e-5" iyz="0" izz="1.2e-4"/>
        </inertial>
    </link>

    <joint name="leg4_wheelConnection" type="continuous">
        <parent link="leg4_3link"/>
        <child link="leg4_wheel"/>
        <origin xyz="0 0 -0.13" rpy="-1.5707 0 -1.5707"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- ================= ros2_control ================= -->
    <!-- Tells ros2_control which joints it owns and that Gazebo provides them. -->
    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>

        <joint name="leg1_mainConnection">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="leg1_2Rotation">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="leg1_3Rotation">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="leg2_mainConnection">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="leg2_2Rotation">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="leg2_3Rotation">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="leg3_mainConnection">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="leg3_2Rotation">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="leg3_3Rotation">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="leg4_mainConnection">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="leg4_2Rotation">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="leg4_3Rotation">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <!-- Loads the controller_manager inside Gazebo and reads our YAML. -->
    <gazebo>
        <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
            <parameters>$(find quadbot_nodes)/config/quadbot_controllers.yaml</parameters>
        </plugin>
    </gazebo>

</robot>
