    <joint name="leg1_3Rotation" type="revolute">
        <parent link="leg1_3joint"/>
        <child link="leg1_3link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
    </joint>

    <!-- wheel - spins freely about its axle at the end of the foot -->
    <link name="leg1_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
            <material name="teal"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
